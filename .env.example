# =============================================================================
# VELA Framework - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# --- LLM Backends (at least one required) ---

# RunPod Serverless (recommended for VELA fine-tuned model)
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
MODEL_NAME=intrect/vela

# MLX Server (Apple Silicon local inference)
VELA_MLX_BASE_URL=http://localhost:8081/v1

# vLLM Direct (local/remote vLLM server)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=intrect/vela

# LM Studio (local inference)
LMSTUDIO_BASE_URL=http://localhost:3000/v1

# --- Search APIs ---

# Naver Search API (Korean news - recommended)
# Get keys at: https://developers.naver.com/apps
NAVER_CLIENT_ID_1=
NAVER_CLIENT_SECRET_1=
# Optional: additional API key pairs for rate limit rotation
# NAVER_CLIENT_ID_2=
# NAVER_CLIENT_SECRET_2=

# --- Optional ---

# Perplexity API (for adversary verification agent)
PERPLEXITY_API_KEY=
